# Copie este arquivo para `.env` na raiz do projeto e personalize os caminhos.

# Vault Obsidian (caminho absoluto)
OBSIDIAN_VAULT_PATH=/caminho/para/seu/Vault

# Persistência vetorial local
VECTORSTORE_PATH=./data/vectorstore

# --- Embeddings ---
# `ollama` (padrão), `sentence_transformers` ou `openai`
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Exemplo alternativo offline
# EMBEDDING_PROVIDER=sentence_transformers
# SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Exemplo OpenAI-compat embeddings
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_EMBED_BASE_URL=https://api.openai.com
# OPENAI_COMPAT_API_KEY=coloque-o-token-aqui

# --- Chat / LLM ---
CHAT_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3.2
#OLLAMA_EMBED_TIMEOUT_SECONDS=300
#OLLAMA_CHAT_TIMEOUT_SECONDS=900

# CHAT_PROVIDER=openai_compat
# OPENAI_COMPAT_BASE_URL=https://api.example.com/v1
# OPENAI_COMPAT_API_KEY=coloque-o-token-aqui
# OPENAI_COMPAT_MODEL=gpt-4o-mini
#OPENAI_COMPAT_TIMEOUT_SECONDS=600

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_JSON=false

# --- Chunking / performance ---
CHUNK_SIZE_CHARS=2000
CHUNK_OVERLAP_CHARS=200
# CHUNK_BY_TOKENS=false
# CHUNK_SIZE_TOKENS=512
# CHUNK_OVERLAP_TOKENS=64
EMBEDDING_BATCH_CONCURRENCY=4
EMBEDDING_REQUEST_BATCH_SIZE=16
# QUERY_EMBED_CACHE_SIZE=128

# --- Retrieval avançado ---
# HYBRID_SEARCH=false
# HYBRID_RRF_K=60
# RERANKER_ENABLED=false
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_N=50
# MMR_LAMBDA=0.5
# RAG_LINK_EXPANSION=false
# RAG_LINK_EXPANSION_TOP_K=3

# --- Observabilidade ---
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Lista separada por vírgulas (glob estilo `.gitignore`)
IGNORE_GLOBS=.obsidian/**,**/node_modules/**,**/*.excalidraw.md,.trash/**
