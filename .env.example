# Copie este arquivo para `.env` na raiz do projeto e personalize os caminhos.

# Vault Obsidian (caminho absoluto)
OBSIDIAN_VAULT_PATH=/caminho/para/seu/Vault

# Persistência vetorial local
VECTORSTORE_PATH=./data/vectorstore

# --- Embeddings ---
# `ollama` (padrão) ou `sentence_transformers`
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Exemplo alternativo offline (`EMBEDDING_PROVIDER=sentence_transformers` já suportado; dependências em requirements.txt)
# EMBEDDING_PROVIDER=sentence_transformers
# SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chat / LLM ---
CHAT_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3.2
# Primeiro /ask pode carregar modelo no Ollama; em CPU aumenta estes valores se aparecer HTTP 502 "Timeout"
#OLLAMA_EMBED_TIMEOUT_SECONDS=300
#OLLAMA_CHAT_TIMEOUT_SECONDS=900

# Modo compatível OpenAI (LocalAI, vLLM, Groq-compat, LiteLLM HTTP, etc.)
# CHAT_PROVIDER=openai_compat
# OPENAI_COMPAT_BASE_URL=https://api.example.com/v1   # exemplo
# OPENAI_COMPAT_API_KEY=coloque-o-token-aqui
# OPENAI_COMPAT_MODEL=gpt-4o-mini                   # exemplo
#OPENAI_COMPAT_TIMEOUT_SECONDS=600

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_JSON=false

# --- Chunking / performance ---
CHUNK_SIZE_CHARS=2000
CHUNK_OVERLAP_CHARS=200
EMBEDDING_BATCH_CONCURRENCY=4
EMBEDDING_REQUEST_BATCH_SIZE=16

# Lista separada por vírgulas (glob estilo `.gitignore`)
IGNORE_GLOBS=.obsidian/**,**/node_modules/**,**/*.excalidraw.md,.trash/**
